# MoAcademy environment variables
#
# The app runs out-of-the-box on bundled seed data with NO configuration.
# To connect a real Supabase backend, copy this file to `.env.local` and fill
# in the values from your Supabase project (Settings -> API).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key, used for seeding/admin scripts. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# AI Study Assistant (optional)
#
# The Assistant tab (global nav -> Assistant) is powered by Claude. Without a
# key the tab still renders and explains how to enable it — no crash.
#
# Get a key at https://console.anthropic.com. This is a SERVER-ONLY secret:
# it is read in the /api/chat route and is never sent to the browser.
ANTHROPIC_API_KEY=

# Which Claude model the assistant uses. Defaults to claude-opus-4-8.
# Set to claude-fable-5 for Anthropic's most capable model (higher cost); the
# route automatically enables server-side fallbacks for it.
ASSISTANT_MODEL=claude-opus-4-8

# ---------------------------------------------------------------------------
# Payments — PayFast (optional)
#
# Without these, checkout uses the built-in demo flow (no real money). Add
# your PayFast merchant credentials (payfast.io -> Settings -> Integration) to
# switch on real card / Instant EFT payments. The values are SERVER-ONLY.
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
# The passphrase you set in the PayFast dashboard (Settings -> Integration).
PAYFAST_PASSPHRASE=
# "false" for live payments; anything else (or unset) uses PayFast's sandbox.
PAYFAST_SANDBOX=true

# Your deployed site's public URL, e.g. https://moacademy.vercel.app — used to
# build PayFast return/cancel/notify URLs. Falls back to the request origin.
NEXT_PUBLIC_SITE_URL=
